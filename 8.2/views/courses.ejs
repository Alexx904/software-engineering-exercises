<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <title>Offerta Formativa Ateneo</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; }
        .course-card { 
            border: 1px solid #ccc; 
            padding: 15px; 
            margin-bottom: 20px; 
            border-radius: 8px;
            background-color: #f9f9f9;
        }
    </style>
</head>
<body>

    <h1>I nostri Corsi di Laurea</h1>

    <% for(let course of courses) { %>
        
        <div class="course-card">
            <h2><%= course.name %></h2>
            <p><strong>Tipologia:</strong> <%= course.type %></p>
            <p><em>Percorso Immagine: <%= course.imagePath %></em></p>
        </div>

    <% } %>

</body>
</html>